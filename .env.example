# ══════════════════════════════════════════════════════════════════════════════
#  Always-In Trading Bot  —  Live Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it contains credentials.
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# MT5 Connection
# Leave LOGIN/PASSWORD/SERVER blank if MT5 is already open and logged in.
# ─────────────────────────────────────────────────────────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=C:/Program Files/MetaTrader 5/terminal64.exe

# ─────────────────────────────────────────────────────────────────────────────
# Symbol names  —  set to YOUR broker's exact symbol name.
#
# How auto-mapping works:
#   1. Apply SYMBOL_PREFIX + name + SYMBOL_SUFFIX  (e.g. "m" + "EURUSD" = "mEURUSD")
#   2. If not found, try SYMBOL_CANDIDATES list in order
#   3. First match in the broker's symbol list wins
#
# Common broker suffixes:  .i  .c  .pro  .m  (ECN/raw accounts)
# Common broker prefixes:  m (micro)  f (futures-style)
# ─────────────────────────────────────────────────────────────────────────────
SYMBOL_PREFIX=
SYMBOL_SUFFIX=

# Override: set the exact broker name directly (skips auto-detection)
GOLD=XAUUSD
SILVER=XAGUSD
EURUSD=EURUSD
GBPUSD=GBPUSD

# Fallback candidates tried in order if the name above is not found
GOLD_CANDIDATES=GOLD,XAUUSD,XAUUSDm,XAUUSDpro,XAUUSD.,GOLD.,GOLDm
SILVER_CANDIDATES=SILVER,XAGUSD,XAGUSDm,XAGUSDpro,XAGUSD.,SILVER.,SILVERm
EURUSD_CANDIDATES=EURUSD,EURUSDm,EURUSDpro,EURUSD.,EURUSDc
GBPUSD_CANDIDATES=GBPUSD,GBPUSDm,GBPUSDpro,GBPUSD.,GBPUSDc

# ─────────────────────────────────────────────────────────────────────────────
# Active symbols  (comma-separated, must match keys above)
# ─────────────────────────────────────────────────────────────────────────────
ACTIVE_SYMBOLS=GOLD,SILVER,EURUSD,GBPUSD

# ─────────────────────────────────────────────────────────────────────────────
# Trading mode
#   DEMO  →  Uses your MT5 demo account  (safe — recommended for first 4 weeks)
#   LIVE  →  Real money — only switch after demo validates the system
# ─────────────────────────────────────────────────────────────────────────────
TRADING_MODE=DEMO

# ─────────────────────────────────────────────────────────────────────────────
# Position sizing  (mirrors the backtest settings exactly)
# ─────────────────────────────────────────────────────────────────────────────
INITIAL_BALANCE=10000.0      # Starting balance for backtesting (Live mode uses real MT5 balance)
RISK_PCT=0.02                # Risk per trade as fraction of current live balance (Max allowed: 0.20, Warns > 0.05)
MAX_LOTS=0.5                 # Hard cap on lot size per symbol (Max allowed: 50.0)
MIN_LOTS=0.01                # Minimum lot size (micro-lot)
ATR_STOP_MULT=1.5            # ATR multiplier for stop-loss sizing

# ─────────────────────────────────────────────────────────────────────────────
# Order execution
# ─────────────────────────────────────────────────────────────────────────────
MAGIC_NUMBER=241010          # Magic number for bot trades
ORDER_COMMENT=AlwaysInBot_v1 # Comment on trades
SLIPPAGE_POINTS=10           # Max slippage in points
ORDER_TIMEOUT_SECONDS=30     # Must be > 0
MAX_RETRIES=3                # Must be >= 1
RETRY_DELAY_SECONDS=5        # Delay between retries

# ─────────────────────────────────────────────────────────────────────────────
# Session filter  (UTC hours — reduce size in illiquid sessions)
# ─────────────────────────────────────────────────────────────────────────────
SESSION_FILTER_ENABLED=true
SESSION_FULL_SIZE_START=7    # London open
SESSION_FULL_SIZE_END=17     # Late NY
SESSION_REDUCED_MULTIPLIER=0.5  # 50% size outside main session

# ─────────────────────────────────────────────────────────────────────────────
# Rollover guard  (block new flips on metals before daily close)
# ─────────────────────────────────────────────────────────────────────────────
ROLLOVER_GUARD_ENABLED=true
ROLLOVER_START_HOUR=21       # UTC — block flips from 21:30
ROLLOVER_START_MIN=30
ROLLOVER_END_HOUR=22         # UTC — resume after 22:05
ROLLOVER_END_MIN=5

# ─────────────────────────────────────────────────────────────────────────────
# Risk limits
# ─────────────────────────────────────────────────────────────────────────────
MAX_DRAWDOWN_PCT=0.08            # 8% drawdown → circuit breaker opens
CIRCUIT_BREAKER_RECOVERY_PCT=0.04 # Recovers when DD drops below this
CB_COOLDOWN_MINUTES=60           # Minutes to wait after CB fires before re-entering
                                  # Prevents death spiral — bot stays flat for 1 full hour
MAX_DAILY_LOSS_USD=500.0         # Stop trading for the day if loss exceeds this
MAX_SPREAD_PIPS_GOLD=80.0        # Skip trade if spread > N pips (GOLD)
MAX_SPREAD_PIPS_SILVER=8.0
MAX_SPREAD_PIPS_FX=3.0

# ─────────────────────────────────────────────────────────────────────────────
# Feature engineering warmup bars
# (enough history to compute EMA 200 + rolling z-score window)
# ─────────────────────────────────────────────────────────────────────────────
WARMUP_BARS_M15=200
WARMUP_BARS_H1=300
WARMUP_BARS_H4=60
WARMUP_BARS_D1=50

# ─────────────────────────────────────────────────────────────────────────────
# Timing
# ─────────────────────────────────────────────────────────────────────────────
BAR_CHECK_INTERVAL_SEC=5    # Check for new H1 bar every N seconds
EXEC_DELAY_SEC=3            # Wait N seconds after bar close before executing
                             # (allows MT5 to finalise the bar)

# ─────────────────────────────────────────────────────────────────────────────
# Telegram notifications  (optional but recommended)
# Get token from @BotFather, get chat_id from @userinfobot
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_ON_FLIP=true
TELEGRAM_NOTIFY_ON_CIRCUIT_BREAKER=true
TELEGRAM_NOTIFY_ON_DAILY_SUMMARY=true
TELEGRAM_DAILY_SUMMARY_HOUR=22   # UTC hour to send daily summary

# ─────────────────────────────────────────────────────────────────────────────
# Stop Loss  (always-in style — wide emergency SL, trailed each bar, no TP)
# ─────────────────────────────────────────────────────────────────────────────
# SL is placed on every position open and trailed each H1 bar.
# It is a crash guard, not a trading tool — sized wide enough to never be hit
# in normal trading but protecting against flash crashes and bot downtime.
#
# TRAIL_STOP_ATR_MULT:
#   SL distance = ATR × this multiplier
#   5.0 means SL sits 5× the hourly ATR away from current price
#   Typical: 3.0 (tighter) to 7.0 (looser)
#
# If SL is hit before the model flips, the bot detects the closed position
# and immediately re-enters in the same direction — maintaining always-in.
# ─────────────────────────────────────────────────────────────────────────────
TRAIL_STOP_ENABLED=true
TRAIL_STOP_ATR_MULT=5.0

# ─────────────────────────────────────────────────────────────────────────────
# Shutdown behaviour
# ─────────────────────────────────────────────────────────────────────────────
# true  (recommended) — close all positions cleanly when bot stops (Ctrl+C)
#                       Bot re-enters at next H1 bar on restart.
# false — leave positions open on stop (only use if you have broker-side stops)
CLOSE_ON_STOP=true

# ─────────────────────────────────────────────────────────────────────────────
# Emergency stop-loss (optional — protects open positions if bot crashes)
# Set to 0 to disable. Recommended: 5–10× your normal ATR stop.
# e.g. GOLD ATR ~$15, so EMERGENCY_STOP_PIPS=1000 = $10 protection buffer
# ─────────────────────────────────────────────────────────────────────────────
EMERGENCY_STOP_PIPS=0
LOG_LEVEL=INFO               # DEBUG / INFO / WARNING / ERROR
LOG_TO_FILE=true
LOG_ROTATION=1 week          # Rotate log files weekly

# ─────────────────────────────────────────────────────────────────────────────
# Terminal dashboard
# ─────────────────────────────────────────────────────────────────────────────
TERMINAL_UI_ENABLED=true
TERMINAL_UI_REFRESH_SECONDS=1.0
TERMINAL_UI_MAX_EVENTS=8
