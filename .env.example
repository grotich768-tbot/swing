# ══════════════════════════════════════════════════════════════════════════════
#  Always-In Trading Bot (V2) —  Live Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it contains credentials.
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Broker Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Sets your spreads and pip values dynamically via broker_config.py
# Options: Eightcap, ICMarkets, Pepperstone, Exness
BROKER=Eightcap

# ─────────────────────────────────────────────────────────────────────────────
# MT5 Connection (Terminal 1)
# Leave LOGIN/PASSWORD/SERVER blank if MT5 is already open and logged in.
# ─────────────────────────────────────────────────────────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH="C:\Program Files\MetaTrader 5\terminal64.exe"

# ─────────────────────────────────────────────────────────────────────────────
# Symbol names  —  set to YOUR broker's exact symbol name.
# ─────────────────────────────────────────────────────────────────────────────
SYMBOL_PREFIX=
SYMBOL_SUFFIX=

# Override: set the exact broker name directly (skips auto-detection)
GOLD=XAUUSD
SILVER=XAGUSD
EURUSD=EURUSD
GBPUSD=GBPUSD
USDJPY=USDJPY
BTCUSD=BTCUSD
ETHUSD=ETHUSD
US500=US500Cash
US100=US100Cash
US30=US30Cash

# Fallback candidates tried in order if the name above is not found
GOLD_CANDIDATES=GOLD,XAUUSD,XAUUSDm,XAUUSDpro,XAUUSD.,GOLD.vx,XAUUSD.vx
SILVER_CANDIDATES=SILVER,XAGUSD,XAGUSDm,XAGUSD.,SILVER.vx,XAGUSD.vx
EURUSD_CANDIDATES=EURUSD,EURUSDm,EURUSD.,EURUSD.vx
GBPUSD_CANDIDATES=GBPUSD,GBPUSDm,GBPUSD.,GBPUSD.vx
USDJPY_CANDIDATES=USDJPY,USDJPYm,USDJPY.,USDJPY.vx
BTCUSD_CANDIDATES=BTCUSD,BTCUSDm,BTCUSD.,XBTUSD,BTCUSD.vx
ETHUSD_CANDIDATES=ETHUSD,ETHUSDm,ETHUSD.,ETHUSD.vx
US500_CANDIDATES=US500Cash,US500m,US500.,US500.vx
US100_CANDIDATES=US100Cash,US100m,US100.,US100.vx
US30_CANDIDATES=US30Cash,US30m,US30.,US30.vx

# ─────────────────────────────────────────────────────────────────────────────
# Active symbols  (comma-separated, must match keys above)
# ─────────────────────────────────────────────────────────────────────────────
ACTIVE_SYMBOLS=GOLD,SILVER,EURUSD,GBPUSD,USDJPY,US500,US100,US30,BTCUSD,ETHUSD

# ─────────────────────────────────────────────────────────────────────────────
# Trading mode
#   DEMO  →  Uses your MT5 demo account  (safe)
#   LIVE  →  Real money
# ─────────────────────────────────────────────────────────────────────────────
TRADING_MODE=DEMO

# ─────────────────────────────────────────────────────────────────────────────
# Position sizing
# ─────────────────────────────────────────────────────────────────────────────
INITIAL_BALANCE=10000.0      # Starting balance for backtesting (Live mode uses real MT5 balance)
RISK_PCT=0.02                # Risk per trade as fraction of current live balance (Max allowed: 0.20, Warns > 0.05)
MAX_LOTS=0.5                 # Hard cap on lot size per symbol (Max allowed: 50.0)
MIN_LOTS=0.01                # Minimum lot size
ATR_STOP_MULT=1.5            # ATR multiplier for stop-loss sizing

# ─────────────────────────────────────────────────────────────────────────────
# Order execution
# ─────────────────────────────────────────────────────────────────────────────
MAGIC_NUMBER=241010
ORDER_COMMENT=AlwaysInBot_v2
SLIPPAGE_POINTS=10
ORDER_TIMEOUT_SECONDS=30     # Must be > 0
MAX_RETRIES=3                # Must be >= 1
RETRY_DELAY_SECONDS=5

# ─────────────────────────────────────────────────────────────────────────────
# Session filter  (UTC hours — reduce size in illiquid sessions)
# ─────────────────────────────────────────────────────────────────────────────
SESSION_FILTER_ENABLED=true
SESSION_FULL_SIZE_START=7    # London open
SESSION_FULL_SIZE_END=17     # Late NY
SESSION_REDUCED_MULTIPLIER=0.5

# ─────────────────────────────────────────────────────────────────────────────
# Rollover guard  (block new flips on metals before daily close)
# ─────────────────────────────────────────────────────────────────────────────
ROLLOVER_GUARD_ENABLED=true
ROLLOVER_START_HOUR=21
ROLLOVER_START_MIN=30
ROLLOVER_END_HOUR=22
ROLLOVER_END_MIN=5

# ─────────────────────────────────────────────────────────────────────────────
# Risk limits
# ─────────────────────────────────────────────────────────────────────────────
MAX_DRAWDOWN_PCT=0.08
CIRCUIT_BREAKER_RECOVERY_PCT=0.04
CB_COOLDOWN_MINUTES=60
MAX_DAILY_LOSS_USD=500.0

# ─────────────────────────────────────────────────────────────────────────────
# Telegram notifications
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_ON_FLIP=true
TELEGRAM_NOTIFY_ON_CIRCUIT_BREAKER=true
TELEGRAM_NOTIFY_ON_DAILY_SUMMARY=true

# ─────────────────────────────────────────────────────────────────────────────
# Terminal dashboard
# ─────────────────────────────────────────────────────────────────────────────
TERMINAL_UI_ENABLED=true
TERMINAL_UI_REFRESH_SECONDS=1.0
TERMINAL_UI_MAX_EVENTS=12

# ─────────────────────────────────────────────────────────────────────────────
# MT5 SECOND TERMINAL (Crypto/Valetax routing via live2.py)
# ─────────────────────────────────────────────────────────────────────────────
MT5_LOGIN2=
MT5_PASSWORD2=
MT5_SERVER2=
MT5_PATH2="C:\Program Files\MetaTrader 5\terminal64.exe"
ACTIVE_SYMBOLS2=BTCUSD,ETHUSD
